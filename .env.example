# TEMPLATE ONLY — this file IS committed, so keep every value BLANK (rule 5).
# Copy this to `.env` (gitignored) and put your REAL keys there. Then mirror the
# same values into the GitHub Actions secrets of the cron repo. See docs/03-setup-guide.md.

# Ideation (primary = Claude Code / Routine — runs in Anthropic's cloud, not here)
CLAUDE_CODE_OAUTH_TOKEN=

# LLM (scripts + ideation fallback)
GEMINI_API_KEY=
GROQ_API_KEY=

# Database
SUPABASE_URL=
SUPABASE_KEY=

# Approval
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_APPROVAL_MODE=webhook       # webhook for Vercel bot; polling only when no Telegram webhook is set

# Telegram control bot (Vercel webhook — see telegram-bot/README.md). Set these in the Vercel
# project env; WEBHOOK_SECRET also goes in local .env so tools/set_telegram_webhook.py can register it.
WEBHOOK_SECRET=                     # any random string; must match the value set in Vercel
GH_PAT=                             # GitHub token (Actions: read+write) so /makeshort can start the run
GH_REPO=                           # e.g. Shaan-alpha/AI-Reel-Factory

# Visuals
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Edit polish (assembly): all optional, sensible defaults, all fail-soft (a filter error
# falls back to a plain render so the daily batch never dies).
ENABLE_XFADE=          # true (default) | false — crossfade transitions between cuts
XFADE_SECONDS=         # crossfade overlap seconds (default 0.35)
ENABLE_GRADE=          # true (default) | false — cinematic color grade
GRADE_CONTRAST=        # default 1.06
GRADE_SATURATION=      # default 1.12
ENABLE_VIGNETTE=       # true (default) | false
ENABLE_GRAIN=          # true (default) | false — subtle film grain
GRAIN_STRENGTH=        # noise alls value (default 8)

# Voice (TTS) — Google Cloud Chirp 3 HD primary; falls back to edge-tts en-IN, then Kokoro.
VOICE_ENGINE=google                 # google | edge | kokoro (the rest follow as a fallback chain)
GOOGLE_TTS_API_KEY=                 # TTS-restricted key; set a $5 budget cap + alert in Google Cloud
GOOGLE_TTS_VOICE=                   # run tools/list_google_voices.py, paste an en-IN Chirp3-HD name
GOOGLE_TTS_LANGUAGE=en-IN

# Captions (active-word karaoke)
CAPTION_FONT=Montserrat             # bundled in assets/fonts; resolved by libass via fontsdir
CAPTION_HIGHLIGHT_COLOR=&H0000FFFF  # ASS &HBBGGRR (yellow) — the active word's fill colour
ENABLE_TEXT_CARDS=true              # burn short on-screen key-point cards (story-specific visuals)
CARD_SECONDS=1.8                    # how long each key-point card flashes

# YouTube publishing
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Config
CHANNEL_NAME=But It Matters         # brand name (also used in disclosure/branding)
NICHE=impact-news                   # daily impact news/info explainers (India + world)
NICHE_LEAN=soft-positive            # science/tech/economy/breakthroughs; avoid partisan/communal
CONTENT_STYLE=daily-impact-explainer   # what happened -> why it matters -> impact
DIGEST_HOUR_UTC=02                  # 08:00 IST ~= 02:30 UTC (adjust to your timezone)
ENABLE_FALLBACK_IDEATION=true       # use Gemini/Groq only if Claude didn't produce ideas
AI_DISCLOSURE=true                  # set YouTube altered/synthetic flag + disclosure line
MIN_SOURCES=2                       # min independent sources before an idea becomes a reel
ENABLE_HUMAN_ANGLE=true             # require a genuine "why it matters" take (originality / anti-AI-slop)
NEWS_RSS_URL=                       # optional: override the Google News RSS feed that seeds ideation
